# --- Dependencias y artefactos de build (lo más pesado) ---
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store

# Salida de Next.js local (se regenera con npm run build en la imagen)
.next
out
dist
build
.turbo
.cache
*.tsbuildinfo

# --- Git y metadatos (no hacen falta para compilar) ---
.git
.gitattributes
.gitignore

# --- Entornos locales (seguridad + innecesarios) ---
.env
.env.*

# --- CI, K8s e infra (no van en el contexto de la app) ---
.github
k8s
docker-compose*.yml
compose*.yml
externalsecrets*.yml

# Nota: no ignorar Dockerfile; debe formar parte del contexto de build.

# --- Documentación y archivos de editor ---
*.md
README*
LICENSE*
CHANGELOG*
.editorconfig
.prettierrc*
.prettierignore
eslint.config.*
.eslintrc*

# --- IDE y herramientas locales ---
.vscode
.idea
*.swp
*.swo
.cursor
**/.cursor/**

# --- SO ---
.DS_Store
Thumbs.db

# --- Tests / cobertura (si existen) ---
coverage
.nyc_output
**/__tests__
**/__mocks__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
jest.config.*
vitest.config.*
playwright.config.*
cypress
e2e

# --- Otros ---
*.log
tmp
temp
