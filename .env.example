# API base URL — must include trailing slash. In deployed envs, points to the
# gateway that exposes the Client API under /client/api/.
NEXT_PUBLIC_API_BASE_URL=

# Public seats.io workspace key (safe to ship to the browser).
NEXT_PUBLIC_SEATS_WORKSPACE_KEY=

# Firebase Web SDK configuration for Client root auth.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_PHONE_AUTH_TESTING=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Site-wide white-label profile selected at build time.
NEXT_PUBLIC_WHITE_LABEL=pwr-ticket

# Feeds Next's `basePath` — prefixes application routes. Leave empty when the
# app sits behind a path-stripping gateway (e.g. APISIX routing /client/* →
# upstream with the prefix stripped). Populate only when the app must answer
# at a subpath without upstream stripping.
NEXT_PUBLIC_BASE_PATH=

# Default event image shown when an event has no image configured or the
# provided image URL cannot be loaded. Can be a relative path under /public
# (e.g. /assets/eventDefault/default.png) or an absolute URL.
NEXT_PUBLIC_DEFAULT_EVENT_IMAGE

# Feeds Next's `assetPrefix` — prefixes asset URLs (_next/static, _next/image,
# etc.) without prefixing routes. Set to the public subpath the gateway
# exposes (e.g. /client) so the browser requests assets through the gateway.
NEXT_PUBLIC_ASSET_PREFIX=

# Hostname added to `images.remotePatterns` at build time so Next's image
# optimizer accepts admin-served event media (e.g. dev-web.pwrticket.mx,
# qa-web.pwrticket.mx). Scoped to /admin/images/**. Leave empty if the
# backend doesn't return absolute URLs to this host.
NEXT_PUBLIC_ADMIN_IMAGE_HOST=

# Base32 secret used by the QR ticket TOTP timer (src/hooks/useQrTimer.ts).
# Required for the My Tickets QR flow; safe to leave empty if you are not
# exercising that flow locally.
NEXT_PUBLIC_SECRET_BASE_32=

# Server-only Firebase Admin SDK credential used by Next.js route handlers.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional override for the HttpOnly session cookie name.
FIREBASE_SESSION_COOKIE_NAME=xbol_client_session

# Optional local HTTP override for Docker E2E.
FIREBASE_SESSION_COOKIE_SECURE=
