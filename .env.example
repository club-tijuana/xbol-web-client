# API base URL — must include trailing slash. In deployed envs, points to the
# gateway that exposes the Client API under /client/api/.
NEXT_PUBLIC_API_BASE_URL=

# Public seats.io workspace key (safe to ship to the browser).
NEXT_PUBLIC_SEATS_WORKSPACE_KEY=

# Asset URL prefix. Empty for local dev (assets resolve under /assets/...).
# In deployed envs that mount the app under a subpath, set to the subpath
# (e.g. /client) so static asset URLs resolve correctly.
NEXT_PUBLIC_BASE_PATH=

# Base32 secret used by the QR ticket TOTP timer (src/hooks/useQrTimer.ts).
# Required for the My Tickets QR flow; safe to leave empty if you are not
# exercising that flow locally.
NEXT_PUBLIC_SECRET_BASE_32=
