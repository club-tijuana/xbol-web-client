{
  "schemas": {
    "publicEnv": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "NEXT_PUBLIC_API_BASE_URL": {
          "validation": "url",
          "type": "string",
          "minLength": 1
        },
        "NEXT_PUBLIC_SEATS_WORKSPACE_KEY": {
          "validation": "uuid",
          "type": "string",
          "minLength": 1
        },
        "NEXT_PUBLIC_FIREBASE_API_KEY": {
          "type": "string",
          "minLength": 1
        },
        "NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN": {
          "type": "string",
          "minLength": 1
        },
        "NEXT_PUBLIC_FIREBASE_PROJECT_ID": {
          "type": "string",
          "minLength": 1
        },
        "NEXT_PUBLIC_FIREBASE_APP_ID": {
          "type": "string",
          "minLength": 1
        },
        "NEXT_PUBLIC_FIREBASE_PHONE_AUTH_TESTING": {
          "type": "string",
          "enum": [
            "true",
            "false"
          ]
        },
        "NEXT_PUBLIC_ENABLE_EMAIL_AUTH": {
          "type": "string",
          "enum": [
            "true",
            "false"
          ]
        },
        "NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": {
          "type": "string"
        },
        "NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET": {
          "type": "string"
        },
        "NEXT_PUBLIC_BASE_PATH": {
          "type": "string"
        },
        "NEXT_PUBLIC_ASSET_PREFIX": {
          "type": "string"
        },
        "NEXT_PUBLIC_ADMIN_IMAGE_HOST": {
          "type": "string"
        },
        "NEXT_PUBLIC_DEFAULT_EVENT_IMAGE": {
          "default": "/assets/eventDefault/default.png",
          "type": "string"
        },
        "NEXT_PUBLIC_SECRET_BASE_32": {
          "type": "string"
        },
        "NEXT_PUBLIC_WHITE_LABEL": {
          "default": "pwr-ticket",
          "type": "string",
          "enum": [
            "pwr-ticket",
            "test-brand"
          ]
        }
      },
      "required": [
        "NEXT_PUBLIC_API_BASE_URL",
        "NEXT_PUBLIC_SEATS_WORKSPACE_KEY",
        "NEXT_PUBLIC_FIREBASE_API_KEY",
        "NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN",
        "NEXT_PUBLIC_FIREBASE_PROJECT_ID",
        "NEXT_PUBLIC_FIREBASE_APP_ID"
      ],
      "envMetadata": {
        "NEXT_PUBLIC_API_BASE_URL": {
          "sensitive": true,
          "exposure": "public-build-time",
          "githubActions": {
            "storage": "secret",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "NEXT_PUBLIC_SEATS_WORKSPACE_KEY": {
          "sensitive": false,
          "exposure": "public-build-time",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "NEXT_PUBLIC_FIREBASE_API_KEY": {
          "sensitive": false,
          "exposure": "public-build-time",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN": {
          "sensitive": false,
          "exposure": "public-build-time",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "NEXT_PUBLIC_FIREBASE_PROJECT_ID": {
          "sensitive": false,
          "exposure": "public-build-time",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "NEXT_PUBLIC_FIREBASE_APP_ID": {
          "sensitive": false,
          "exposure": "public-build-time",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "NEXT_PUBLIC_FIREBASE_PHONE_AUTH_TESTING": {
          "sensitive": false,
          "exposure": "public-build-time"
        },
        "NEXT_PUBLIC_ENABLE_EMAIL_AUTH": {
          "sensitive": false,
          "exposure": "public-build-time"
        },
        "NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": {
          "sensitive": false,
          "exposure": "public-build-time",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET": {
          "sensitive": false,
          "exposure": "public-build-time",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "NEXT_PUBLIC_BASE_PATH": {
          "sensitive": false,
          "exposure": "public-build-time",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "NEXT_PUBLIC_ASSET_PREFIX": {
          "sensitive": false,
          "exposure": "public-build-time",
          "githubActions": {
            "storage": "variable",
            "scope": "repository"
          }
        },
        "NEXT_PUBLIC_ADMIN_IMAGE_HOST": {
          "sensitive": false,
          "exposure": "public-build-time",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "NEXT_PUBLIC_DEFAULT_EVENT_IMAGE": {
          "sensitive": false,
          "exposure": "public-build-time",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "NEXT_PUBLIC_SECRET_BASE_32": {
          "sensitive": true,
          "exposure": "public-build-time",
          "githubActions": {
            "storage": "secret",
            "scope": "repository"
          }
        },
        "NEXT_PUBLIC_WHITE_LABEL": {
          "sensitive": false,
          "exposure": "public-build-time",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        }
      }
    },
    "serverEnv": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "FIREBASE_SERVICE_ACCOUNT_JSON": {
          "type": "string",
          "minLength": 1,
          "validation": "json-object"
        },
        "FIREBASE_SESSION_COOKIE_NAME": {
          "default": "xbol_client_session",
          "type": "string",
          "minLength": 1
        },
        "FIREBASE_SESSION_COOKIE_SECURE": {
          "type": "string",
          "enum": [
            "true",
            "false"
          ]
        },
        "SITE_ACCESS_MODE": {
          "default": "open",
          "type": "string",
          "enum": [
            "open",
            "landing"
          ]
        },
        "SITE_ACCESS_LANDING_IMAGE_URL": {
          "type": "string",
          "format": "uri"
        },
        "SITE_ACCESS_ALLOWED_CIDRS": {
          "type": "string"
        },
        "SITE_ACCESS_CLIENT_IP_HEADER": {
          "default": "x-forwarded-for",
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "FIREBASE_SERVICE_ACCOUNT_JSON"
      ],
      "envMetadata": {
        "FIREBASE_SERVICE_ACCOUNT_JSON": {
          "sensitive": true,
          "exposure": "server-runtime",
          "githubActions": {
            "storage": "secret",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "FIREBASE_SESSION_COOKIE_NAME": {
          "sensitive": false,
          "exposure": "server-runtime",
          "githubActions": {
            "storage": "variable",
            "scope": "repository"
          }
        },
        "FIREBASE_SESSION_COOKIE_SECURE": {
          "sensitive": false,
          "exposure": "server-runtime",
          "githubActions": {
            "storage": "variable",
            "scope": "repository"
          }
        },
        "SITE_ACCESS_MODE": {
          "sensitive": false,
          "exposure": "server-runtime",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "SITE_ACCESS_LANDING_IMAGE_URL": {
          "sensitive": false,
          "exposure": "server-runtime",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "SITE_ACCESS_ALLOWED_CIDRS": {
          "sensitive": false,
          "exposure": "server-runtime",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        },
        "SITE_ACCESS_CLIENT_IP_HEADER": {
          "sensitive": false,
          "exposure": "server-runtime",
          "githubActions": {
            "storage": "variable",
            "scope": "environment",
            "environments": [
              "GCP_DEV",
              "GCP_QA"
            ]
          }
        }
      }
    }
  }
}
